{
  "name": "pdfcrop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write . | { grep -v '(unchanged)$'; true; }",
    "format:check": "prettier --check --log-level warn .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "comlink": "^4.4.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.8.69",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.5"
  },
  "packageManager": "pnpm@10.33.3"
}
